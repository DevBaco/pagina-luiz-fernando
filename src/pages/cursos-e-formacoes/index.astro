---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { site, whatsappUrl } from '../../data/site';

const courseIncludes = [
  'Fundamentos da massoterapia Ayurvédica',
  'Formação em massagem Abhyanga',
  'Técnica, escuta e presença no toque',
  'Prática para atender com segurança',
];
---

<BaseLayout
  title="Cursos e Formações | Luiz Reis"
  description="Formação em massoterapia Ayurvédica e massagem Abhyanga, cursos de Ayurveda e a Comunidade Toque Inteligente."
>
  <PageHeader
    title="Cursos e Formações"
    eyebrow="Ayurveda, Astrologia Védica e toque terapêutico"
    backgroundImage="/images/page-header-cursos-e-formacoes.webp"
  />

  <section class="our-pricing light-section">
    <div class="container">
      <div class="row section-row align-items-center">
        <div class="col-xl-7">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Curso em destaque</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Formação em Massoterapia Ayurvédica e Massagem Abhyanga</h2>
          </div>
        </div>
        <div class="col-xl-5">
          <div class="section-title-content wow fadeInUp" data-wow-delay="0.2s">
            <p>Uma formação completa para quem deseja aprender a massagem Abhyanga e levar o toque terapêutico Ayurvédico para a sua prática. Curso disponível na plataforma Hotmart.</p>
          </div>
        </div>
      </div>

      <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10 pricing-single">
          <div class="pricing-item highlighted-box wow fadeInUp">
            <div class="pricing-item-header course-card-header">
              <div class="icon-box"><img src="/images/icon-pricing-2.svg" alt="" /></div>
              <div class="pricing-item-content">
                <span class="pricing-item-title">Massoterapia Ayurvédica</span>
                <p>Formação em massagem Abhyanga com fundamentos, técnica e prática.</p>
              </div>
              <a
                class="hotmart-course-brand"
                href={site.hotmartCourseUrl}
                target="_blank"
                rel="noopener"
                aria-label="Ver a Formação em Massoterapia Ayurvédica e Massagem Abhyanga na Hotmart"
              >
                <span>Curso disponível na</span>
                <img src="/images/hotmart-logo.svg" alt="Hotmart" />
              </a>
            </div>
            <div class="pricing-item-body">
              <div class="pricing-item-body-list">
                <h3>O que você aprende:</h3>
                <ul>
                  {courseIncludes.map((item) => <li>{item}</li>)}
                </ul>
              </div>
              <div class="pricing-item-btn">
                <a href={site.hotmartCourseUrl} class="btn-default btn-highlighted" target="_blank" rel="noopener">Ver curso na Hotmart</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="simple-page-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-xl-6">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Toque Inteligente</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Formações para quem deseja cuidar com mais profundidade</h2>
            <p class="wow fadeInUp" data-wow-delay="0.2s">Os cursos unem fundamentos de Ayurveda, Astrologia Védica, escuta, presença e prática corporal para terapeutas, massoterapeutas e pessoas em caminho de desenvolvimento humano.</p>
            <p class="wow fadeInUp" data-wow-delay="0.3s">A Comunidade Toque Inteligente será o primeiro canal para receber conteúdos, datas e novas turmas.</p>
          </div>
          <div class="about-us-btn wow fadeInUp" data-wow-delay="0.4s">
            <a class="btn-default" href={whatsappUrl} target="_blank" rel="noopener">Entrar para a comunidade</a>
          </div>
        </div>
        <div class="col-xl-6">
          <figure class="image-anime"><img src="/images/cursos-e-formacoes.webp" alt="Luiz Reis em encontro de cursos e formações" /></figure>
        </div>
      </div>
    </div>
  </section>

  <section class="book-appointment dark-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-xl-8">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Comunidade Toque Inteligente</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Receba avisos sobre encontros, conteúdos e próximas turmas</h2>
          </div>
        </div>
        <div class="col-xl-4">
          <div class="section-btn wow fadeInUp" data-wow-delay="0.2s">
            <a class="btn-default btn-highlighted" href={whatsappUrl} target="_blank" rel="noopener">Entrar para a comunidade</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
