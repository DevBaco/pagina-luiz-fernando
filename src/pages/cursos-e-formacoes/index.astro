---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { site, whatsappUrl } from '../../data/site';

const courseIncludes = [
  'Fundamentos da massoterapia Ayurvedica',
  'Formacao em massagem Abhyanga',
  'Tecnica, escuta e presenca no toque',
  'Pratica para atender com seguranca',
];
---

<BaseLayout
  title="Cursos e Formacoes | Luiz Reis"
  description="Formacao em massoterapia Ayurvedica e massagem Abhyanga, cursos de Ayurveda e a Comunidade Toque Inteligente."
>
  <PageHeader title="Cursos e Formacoes" eyebrow="Ayurveda, Astrologia Vedica e toque terapeutico" />

  <section class="simple-page-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-xl-6">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Toque Inteligente</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Formacoes para quem deseja cuidar com mais profundidade</h2>
            <p class="wow fadeInUp" data-wow-delay="0.2s">Os cursos unem fundamentos de Ayurveda, Astrologia Vedica, escuta, presenca e pratica corporal para terapeutas, massoterapeutas e pessoas em caminho de desenvolvimento humano.</p>
            <p class="wow fadeInUp" data-wow-delay="0.3s">A Comunidade Toque Inteligente sera o primeiro canal para receber conteudos, datas e novas turmas.</p>
          </div>
          <div class="about-us-btn wow fadeInUp" data-wow-delay="0.4s">
            <a class="btn-default" href={whatsappUrl} target="_blank" rel="noopener">Entrar para a comunidade</a>
          </div>
        </div>
        <div class="col-xl-6">
          <figure class="image-anime"><img src="/images/our-feature-image-1.jpg" alt="Cursos e formacoes com Luiz Reis" /></figure>
        </div>
      </div>
    </div>
  </section>

  <section class="our-pricing light-section">
    <div class="container">
      <div class="row section-row align-items-center">
        <div class="col-xl-7">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Curso em destaque</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Formacao em Massoterapia Ayurvedica e Massagem Abhyanga</h2>
          </div>
        </div>
        <div class="col-xl-5">
          <div class="section-title-content wow fadeInUp" data-wow-delay="0.2s">
            <p>Uma formacao completa para quem deseja aprender a massagem Abhyanga e levar o toque terapeutico Ayurvedico para a sua pratica. Curso disponivel na plataforma Hotmart.</p>
          </div>
        </div>
      </div>

      <div class="row justify-content-center">
        <div class="col-xl-7 col-lg-9">
          <div class="pricing-item highlighted-box wow fadeInUp">
            <div class="pricing-item-header">
              <div class="icon-box"><img src="/images/icon-pricing-2.svg" alt="" /></div>
              <div class="pricing-item-content">
                <span class="pricing-item-title">Massoterapia Ayurvedica</span>
                <p>Formacao em massagem Abhyanga com fundamentos, tecnica e pratica.</p>
              </div>
            </div>
            <div class="pricing-item-body">
              <div class="pricing-item-body-list">
                <h3>O que voce aprende:</h3>
                <ul>
                  {courseIncludes.map((item) => <li>{item}</li>)}
                </ul>
              </div>
              <div class="pricing-item-btn">
                <a href={site.hotmartCourseUrl} class="btn-default btn-highlighted" target="_blank" rel="noopener">Ver curso na Hotmart</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="book-appointment dark-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-xl-8">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Comunidade Toque Inteligente</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Receba avisos sobre encontros, conteudos e proximas turmas</h2>
          </div>
        </div>
        <div class="col-xl-4">
          <div class="section-btn wow fadeInUp" data-wow-delay="0.2s">
            <a class="btn-default btn-highlighted" href={whatsappUrl} target="_blank" rel="noopener">Entrar para a comunidade</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
