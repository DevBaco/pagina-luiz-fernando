---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { site, whatsappUrl } from '../data/site';

const trust = [
  '15+ anos de experiência',
  'Professor de Ayurveda',
  'Atendimentos em Belo Horizonte e Nova Lima',
  'Centenas de pessoas acompanhadas',
  'Especialista em terapias corporais e saúde integrativa',
];

const tools = [
  {
    icon: '/images/icon-approach-item-1.svg',
    title: 'Escuta e presença',
    text: 'Antes da técnica vem o olhar. Entender a sua história por inteiro é o início de todo o cuidado.',
    li: 'A escuta vem antes de tudo',
  },
  {
    icon: '/images/icon-approach-item-2.svg',
    title: 'Ayurveda e toque',
    text: 'Consulta, Abhyanga, alimentação e rotina se combinam conforme o que o seu momento pede.',
    li: 'Técnicas a serviço de você',
  },
  {
    icon: '/images/icon-approach-item-3.svg',
    title: 'Cuidado individual',
    text: 'Nenhum plano é igual ao outro. O caminho é construído para caber na sua vida real.',
    li: 'Um plano para a sua vida real',
  },
];
---

<BaseLayout
  title="Sobre Luiz Reis | Ayurveda e terapias integrativas em BH"
  description="Conheça Luiz Reis: 15+ anos cuidando de pessoas com Ayurveda, toque terapêutico, escuta e saúde integrativa em Belo Horizonte e Nova Lima."
>
  <PageHeader title="Sobre Luiz Reis" eyebrow="Escuta, presença e cuidado individual" />

  <section class="about-us">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-xl-6">
          <div class="about-us-content">
            <div class="section-title">
              <span class="section-sub-title wow fadeInUp">Quem conduz o cuidado</span>
              <h2 class="text-anime-style-3" data-cursor="-opaque">Mais do que aplicar técnicas, o trabalho é entender o que está acontecendo com você</h2>
              <p class="wow fadeInUp" data-wow-delay="0.2s">Luiz Reis atua com Ayurveda, terapias corporais, saúde integrativa e formação de terapeutas. A proposta é acolher pessoas que vivem cansaço, ansiedade, dores, insônia e a sensação de estar vivendo no automático.</p>
              <p class="wow fadeInUp" data-wow-delay="0.3s">O atendimento une escuta, presença, toque terapêutico e orientações individualizadas para reorganizar rotina, corpo e emoções.</p>
            </div>
            <ul class="trust-list wow fadeInUp" data-wow-delay="0.4s">
              {trust.map((item) => <li>{item}</li>)}
            </ul>
            <div class="about-us-btn wow fadeInUp" data-wow-delay="0.5s">
              <a class="btn-default" href={whatsappUrl} target="_blank" rel="noopener">Agendar conversa</a>
            </div>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="about-us-image-box wow fadeInUp">
            <div class="about-us-image-box-1">
              <div class="about-us-image-1">
                <figure class="image-anime"><img src="/images/about-us-image-1.jpg" alt={site.name} /></figure>
              </div>
              <div class="about-us-image-2">
                <figure class="image-anime"><img src="/images/about-us-image-2.jpg" alt="Ambiente de cuidado" /></figure>
              </div>
            </div>
            <div class="about-us-image-box-2">
              <div class="about-us-image-3">
                <figure class="image-anime"><img src="/images/about-us-image-3.jpg" alt="Terapia corporal" /></figure>
              </div>
              <div class="about-image-content">
                <a href={whatsappUrl} target="_blank" rel="noopener">WhatsApp: {site.phoneLabel}</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="our-approach light-section">
    <div class="container">
      <div class="row section-row align-items-center">
        <div class="col-xl-7">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">A caixa de ferramentas</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Ajudo pessoas a reencontrar saúde, vitalidade e presença através de um cuidado verdadeiramente individual</h2>
          </div>
        </div>
        <div class="col-xl-5">
          <div class="section-title-content wow fadeInUp" data-wow-delay="0.2s">
            <p>Ayurveda, toque, alimentação e xamanismo entram quando fazem sentido. O que você recebe é a experiência de ser acolhido e conduzido.</p>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-lg-12">
          <div class="approach-items-list">
            {tools.map((tool, index) => (
              <div class="approach-item wow fadeInUp" data-wow-delay={`${index * 0.2}s`}>
                <div class="approach-item-header">
                  <div class="icon-box"><img src={tool.icon} alt="" /></div>
                  <div class="approach-item-content">
                    <h3>{tool.title}</h3>
                    <p>{tool.text}</p>
                  </div>
                </div>
                <div class="approach-item-list">
                  <ul><li>{tool.li}</li></ul>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="book-appointment dark-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-xl-8">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Primeiro passo</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Talvez o que você procure não seja uma técnica, é alguém que organize o caos</h2>
          </div>
        </div>
        <div class="col-xl-4">
          <div class="section-btn wow fadeInUp" data-wow-delay="0.2s">
            <a class="btn-default btn-highlighted" href={whatsappUrl} target="_blank" rel="noopener">Agendar conversa</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
