---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { whatsappUrl } from '../../data/site';

const pillars = [
  {
    icon: '/images/icon-benefits-item-1.svg',
    title: 'Pausa e descanso',
    text: 'Interromper o ciclo de sobrecarga e permitir que corpo e mente finalmente desacelerem.',
  },
  {
    icon: '/images/icon-benefits-item-2.svg',
    title: 'Presenca e escuta',
    text: 'Um espaco para se olhar por inteiro, sem pressa e sem a cobranca de estar sempre funcionando.',
  },
  {
    icon: '/images/icon-approach-item-3.svg',
    title: 'Reorganizacao integral',
    text: 'Cuidado com corpo, alimentacao e emocoes para reencontrar direcao e vitalidade.',
  },
];
---

<BaseLayout
  title="Despertar da Consciencia | Retiro Despertar Shamana"
  description="Retiro de tratamento Despertar Shamana: pausa, presenca e reorganizacao integral para quem precisa interromper o ciclo de sobrecarga."
>
  <PageHeader title="Despertar da Consciencia" eyebrow="Retiro de tratamento Despertar Shamana" />

  <section class="service-single-content-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-xl-6">
          <div class="page-single-image">
            <figure class="image-anime"><img src="/images/intro-video-image.jpg" alt="Retiro Despertar Shamana" /></figure>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Tratamento profundo</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Um espaco de pausa, presenca e reorganizacao integral</h2>
            <p class="wow fadeInUp" data-wow-delay="0.2s">O Retiro de tratamento Despertar Shamana e uma experiencia para quem chegou ao limite da sobrecarga e sente que precisa recomecar. Nao e sobre aprender uma tecnica — e sobre parar, escutar o corpo e reencontrar direcao.</p>
            <p class="wow fadeInUp" data-wow-delay="0.3s">Para quem ja cuidou de todos e esqueceu de si, o retiro e um convite para voltar a se sentir por inteiro.</p>
            <div class="about-us-btn wow fadeInUp" data-wow-delay="0.4s">
              <a class="btn-default" href={whatsappUrl} target="_blank" rel="noopener">Tenho interesse</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="our-benefit light-section">
    <div class="container">
      <div class="row section-row align-items-center">
        <div class="col-xl-7">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">O que voce vive no retiro</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Tres pilares de um cuidado que restaura</h2>
          </div>
        </div>
        <div class="col-xl-5">
          <div class="section-title-content wow fadeInUp" data-wow-delay="0.2s">
            <p>Mais do que descansar, o retiro cria as condicoes para que voce se reorganize por dentro e volte diferente.</p>
          </div>
        </div>
      </div>

      <div class="row">
        {pillars.map((pillar, index) => (
          <div class="col-xl-4 col-md-6">
            <div class="approach-item wow fadeInUp" data-wow-delay={`${index * 0.2}s`}>
              <div class="approach-item-header">
                <div class="icon-box"><img src={pillar.icon} alt="" /></div>
                <div class="approach-item-content">
                  <h3>{pillar.title}</h3>
                  <p>{pillar.text}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="book-appointment dark-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-xl-8">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Proxima edicao</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Quero ser avisado sobre datas e vagas</h2>
          </div>
        </div>
        <div class="col-xl-4">
          <div class="section-btn wow fadeInUp" data-wow-delay="0.2s">
            <a class="btn-default btn-highlighted" href={whatsappUrl} target="_blank" rel="noopener">Falar no WhatsApp</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
