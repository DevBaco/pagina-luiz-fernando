---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { whatsappUrl } from '../../data/site';

const benefits = [
  {
    icon: '/images/icon-service-benefits-item-1.svg',
    title: 'Relaxamento profundo e alívio do estresse',
    text: 'O toque conduz o sistema nervoso de volta ao descanso para quem vive em estado de alerta constante.',
  },
  {
    icon: '/images/icon-service-benefits-item-2.svg',
    title: 'Alívio de dores e tensões',
    text: 'Trabalho direcionado para tensão muscular, dores recorrentes e a rigidez que a rotina acumula.',
  },
  {
    icon: '/images/icon-service-benefits-item-3.svg',
    title: 'Sono e digestão mais equilibrados',
    text: 'Ao regular o sistema nervoso, a massagem apoia noites de sono melhores e um corpo menos sobrecarregado.',
  },
  {
    icon: '/images/icon-service-benefits-item-4.svg',
    title: 'Reconexão com o próprio corpo',
    text: 'Mais do que aliviar sintomas, é um retorno ao corpo para quem anda vivendo no automático.',
  },
];
---

<BaseLayout
  title="Massagens Terapêuticas em BH | Abhyanga e toque terapêutico"
  description="Abhyanga e toque terapêutico em Belo Horizonte e Nova Lima para estresse, dores recorrentes, insônia e regulação do sistema nervoso."
>
  <PageHeader
    title="Massagens Terapêuticas"
    eyebrow="Abhyanga e toque terapêutico"
    backgroundImage="/images/page-header-massagens-terapeuticas.webp"
  />

  <section class="service-single-content-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-xl-6">
          <div class="page-single-image">
            <figure class="image-anime"><img src="/images/service-image-2.jpg" alt="Massagem terapêutica Abhyanga" /></figure>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Cuidado pelo corpo</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Um toque que ajuda o sistema nervoso a lembrar como descansar</h2>
            <p class="wow fadeInUp" data-wow-delay="0.2s">A massagem terapêutica é indicada para quem vive tensão, estresse, dores recorrentes, insônia e dificuldade de relaxar. Cada sessão considera o seu momento físico e emocional — não há um roteiro único, há o que o seu corpo precisa hoje.</p>
            <p class="wow fadeInUp" data-wow-delay="0.3s">A Abhyanga, tradição associada à Ayurveda, une óleos e movimentos que favorecem circulação, presença e a sensação de voltar para dentro de si.</p>
            <div class="about-us-btn wow fadeInUp" data-wow-delay="0.4s">
              <a class="btn-default" href={whatsappUrl} target="_blank" rel="noopener">Agendar conversa</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="our-services light-section">
    <div class="container">
      <div class="row section-row align-items-center">
        <div class="col-xl-7">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Para que serve</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">O que a massagem terapêutica pode fazer por você</h2>
          </div>
        </div>
        <div class="col-xl-5">
          <div class="section-title-content wow fadeInUp" data-wow-delay="0.2s">
            <p>Ela não é um luxo pontual. É parte de um cuidado que reorganiza corpo, sono e emoções ao longo do tempo.</p>
          </div>
        </div>
      </div>

      <div class="service-benefits-item-list">
        {benefits.map((benefit, index) => (
          <div class="service-benefits-item wow fadeInUp" data-wow-delay={`${(index % 2) * 0.2}s`}>
            <div class="icon-box"><img src={benefit.icon} alt="" /></div>
            <div class="service-benefits-item-content">
              <h3>{benefit.title}</h3>
              <p>{benefit.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="book-appointment dark-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-xl-8">
          <div class="section-title">
            <span class="section-sub-title wow fadeInUp">Próximo passo</span>
            <h2 class="text-anime-style-3" data-cursor="-opaque">Reserve um tempo para o seu corpo descansar de verdade</h2>
          </div>
        </div>
        <div class="col-xl-4">
          <div class="section-btn wow fadeInUp" data-wow-delay="0.2s">
            <a class="btn-default btn-highlighted" href={whatsappUrl} target="_blank" rel="noopener">Agendar pelo WhatsApp</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
