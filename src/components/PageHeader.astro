---
interface Props {
  title: string;
  eyebrow?: string;
}

const { title, eyebrow = 'Luiz Reis' } = Astro.props;
---

<div class="page-header parallaxie">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <div class="page-header-box">
          <span class="section-sub-title wow fadeInUp">{eyebrow}</span>
          <h1 class="text-anime-style-3" data-cursor="-opaque">{title}</h1>
        </div>
      </div>
    </div>
  </div>
</div>
