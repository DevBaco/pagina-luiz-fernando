---
interface Props {
  title: string;
  eyebrow?: string;
  backgroundImage?: string;
}

const { title, backgroundImage = '/images/page-header-bg.jpg' } = Astro.props;
---

<div
  class="page-header parallaxie"
  style={`--page-header-image: url("${backgroundImage}")`}
>
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <div class="page-header-box">
          <h1 class="text-anime-style-3" data-cursor="-opaque">{title}</h1>
          <nav class="wow fadeInUp">
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><a href="/">Home</a></li>
              <li class="breadcrumb-item active" aria-current="page">{title}</li>
            </ol>
          </nav>
        </div>
      </div>
    </div>
  </div>
</div>
