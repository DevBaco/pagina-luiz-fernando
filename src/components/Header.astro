---
import { site, whatsappUrl } from '../data/site';
---

<header class="main-header">
  <div class="header-sticky">
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand" href="/">
          <img src="/images/logo-luizz-reeiss.png" alt="Luizz_C_Reeiss — Medicina Ayurveda" class="brand-logo" />
        </a>

        <div class="collapse navbar-collapse main-menu">
          <div class="nav-menu-wrapper">
            <ul class="navbar-nav mr-auto" id="menu">
              <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="/sobre/">Sobre</a></li>
              <li class="nav-item submenu"><a class="nav-link" href="/atendimentos/">Atendimentos</a>
                <ul>
                  <li class="nav-item"><a class="nav-link" href="/atendimentos/">Todos os atendimentos</a></li>
                  <li class="nav-item"><a class="nav-link" href="/massagens-terapeuticas/">Massagens Terapêuticas</a></li>
                  <li class="nav-item"><a class="nav-link" href="/despertar-da-consciencia/">Despertar da Consciência</a></li>
                </ul>
              </li>
              <li class="nav-item"><a class="nav-link" href="/cursos-e-formacoes/">Cursos e Formações</a></li>
              <li class="nav-item"><a class="nav-link" href="/blog/">Blog</a></li>
              <li class="nav-item"><a class="nav-link" href="/contato/">Contato</a></li>
              <li class="nav-item highlighted-menu"><a class="nav-link" href={whatsappUrl} target="_blank" rel="noopener">WhatsApp</a></li>
            </ul>
          </div>
          <div class="header-btn">
            <a href={whatsappUrl} class="btn-default btn-highlighted" target="_blank" rel="noopener">Agendar conversa</a>
          </div>
        </div>
        <div class="navbar-toggle"></div>
      </div>
    </nav>
    <div class="responsive-menu"></div>
  </div>
</header>
